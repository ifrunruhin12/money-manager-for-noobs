# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=money_manager
POSTGRES_USER=money_manager
POSTGRES_PASSWORD=changeme

# Full DSN used by the app (must match the values above)
DATABASE_URL=postgres://money_manager:changeme@db:5432/money_manager?sslmode=disable

# ── App ───────────────────────────────────────────────────────────────────────
PORT=8080
LOG_LEVEL=info

# Required — generate a strong random value for production
JWT_SECRET=change-me-to-a-strong-random-secret
JWT_EXPIRY=24h

# ── Optional tuning ───────────────────────────────────────────────────────────
ENABLE_EVENT_LOG=true
BALANCE_STALENESS_THRESHOLD=5m
RATE_LIMIT_RPM=60

# DB pool (defaults shown — override only if needed)
# DB_MAX_CONNS=20
# DB_MIN_CONNS=2
# DB_MAX_CONN_LIFETIME=30m
# DB_MAX_CONN_IDLE_TIME=5m
# DB_HEALTH_CHECK_PERIOD=1m
# DB_MAX_CONN_LIFETIME_JITTER=5m
# DB_PING_TIMEOUT=5s
